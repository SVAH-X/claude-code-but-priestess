{
  "name": "claude-code-but-priestess",
  "version": "0.7.6",
  "description": "A cross-platform tray companion that lets you chat with 普瑞赛斯, backed by local Claude Code or Codex CLI usage.",
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-electron.js",
    "start": "node scripts/run-electron.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "lint": "node scripts/check-assets.js",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "menubar",
    "electron",
    "windows",
    "macos",
    "claude-code",
    "codex"
  ],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "local.claude-code-but-priestess.menubar",
    "productName": "PRTS",
    "publish": [
      {
        "provider": "github",
        "owner": "SVAH-X",
        "repo": "claude-code-but-priestess"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "!**/.DS_Store",
      "!assets/character/casual-src/**",
      "!assets/character/Nano Banana Workspace Image.png",
      "!assets/character/new*.png",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets/build"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "assets/character/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "artifactName": "PRTS-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
